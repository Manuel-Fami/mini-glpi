{% extends 'base.html.twig' %}

{% block title %}Tests PHPUnit — Documentation — Mini GLPI{% endblock %}

{% block body %}

<div class="mb-6">
    <a href="{{ path('app_docs') }}" class="text-sm text-gray-500 hover:text-gray-700">← Documentation</a>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">Tests PHPUnit</h1>
    <p class="text-sm text-gray-500 mt-1">Tests unitaires et fonctionnels côté PHP</p>
</div>

<div class="space-y-6 max-w-3xl">

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-3">Stratégie</h2>
        <p class="text-sm text-gray-600">
            Deux niveaux complémentaires : les <strong>tests unitaires</strong> isolent la logique métier du service
            en mockant l'EntityManager, et les <strong>tests fonctionnels</strong> simulent des requêtes HTTP réelles
            avec routage, sécurité et rendu Twig via <code class="bg-gray-100 px-1 rounded text-xs">WebTestCase</code>.
        </p>
        <p class="text-sm text-gray-600 mt-2">
            Le bundle <code class="bg-gray-100 px-1 rounded text-xs">dama/doctrine-test-bundle</code> enveloppe chaque
            test fonctionnel dans une transaction annulée automatiquement — la base repart d'un état propre à chaque test.
        </p>
    </div>

    {# ---------------------------------------------------------------- #}
    {# Tests unitaires #}
    {# ---------------------------------------------------------------- #}

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">
            Tests unitaires —
            <code class="text-blue-600 text-sm">TicketServiceTest</code>
        </h2>
        <p class="text-sm text-gray-600 mb-4">
            L'<code class="bg-gray-100 px-1 rounded text-xs">EntityManagerInterface</code> est mocké pour éviter
            toute dépendance à la base de données.
        </p>

        <div class="space-y-2">

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-1">create()</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testCreateTicketSetsCorrectProperties()</p>
                <p class="text-gray-500 mt-1">Vérifie les propriétés et le statut initial <strong>OPEN</strong>.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">startProgress()</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testStartProgressChangesStatusToInProgress()</p>
                <p class="text-gray-500 mt-1">Transition <strong>OPEN → IN_PROGRESS</strong>.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testStartProgressOnNonOpenTicketThrowsLogicException()</p>
                <p class="text-gray-500 mt-1"><code class="bg-white px-1 rounded border border-gray-200">LogicException</code> si le ticket n'est pas <strong>OPEN</strong>, <code class="bg-white px-1 rounded border border-gray-200">flush</code> jamais appelé.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">close()</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testCloseOpenTicketChangesStatusToClosed()</p>
                <p class="text-gray-500 mt-1">Transition <strong>OPEN → CLOSED</strong>.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testCloseAlreadyClosedTicketThrowsLogicException()</p>
                <p class="text-gray-500 mt-1"><code class="bg-white px-1 rounded border border-gray-200">LogicException</code> si le ticket est déjà fermé.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">reopen()</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testReopenClosedTicketChangesStatusToOpen()</p>
                <p class="text-gray-500 mt-1">Transition <strong>CLOSED → OPEN</strong>.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testReopenNonClosedTicketThrowsLogicException()</p>
                <p class="text-gray-500 mt-1"><code class="bg-white px-1 rounded border border-gray-200">LogicException</code> si le ticket n'est pas <strong>CLOSED</strong>.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">assign()</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testAssignSetsAssignedToUser()</p>
                <p class="text-gray-500 mt-1">Vérifie que <code class="bg-white px-1 rounded border border-gray-200">assignedTo</code> est correctement défini.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">addComment()</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testAddCommentCreatesCommentWithCorrectProperties()</p>
                <p class="text-gray-500 mt-1">Vérifie le contenu, l'auteur et le ticket associé au commentaire créé.</p>
            </div>

        </div>
    </div>

    {# ---------------------------------------------------------------- #}
    {# Tests fonctionnels #}
    {# ---------------------------------------------------------------- #}

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">
            Tests fonctionnels —
            <code class="text-blue-600 text-sm">TicketControllerTest</code>
        </h2>
        <p class="text-sm text-gray-600 mb-4">
            Des helpers internes (<code class="bg-gray-100 px-1 rounded text-xs">loginAs</code>,
            <code class="bg-gray-100 px-1 rounded text-xs">createOpenTicket</code>,
            <code class="bg-gray-100 px-1 rounded text-xs">createClosedTicket</code>,
            <code class="bg-gray-100 px-1 rounded text-xs">createAssignedTicket</code>)
            évitent la duplication entre les tests.
        </p>

        <div class="space-y-2">

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-1">Accès & navigation</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testUnauthenticatedAccessRedirectsToLogin()</p>
                <p class="text-gray-500 mt-1"><code class="bg-white px-1 rounded border border-gray-200">GET /tickets</code> sans session → redirect <code class="bg-white px-1 rounded border border-gray-200">/login</code>.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testAuthenticatedUserCanViewTicketDetail()</p>
                <p class="text-gray-500 mt-1">Un utilisateur connecté accède à la page de détail.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">Création & modification</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testCreateTicketViaHttp()</p>
                <p class="text-gray-500 mt-1">Flux complet : formulaire → redirect → ticket visible dans la liste.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testEditClosedTicketRedirectsWithError()</p>
                <p class="text-gray-500 mt-1">Modifier un ticket fermé → redirect avec flash d'erreur.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">Commentaires</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testTechCanCommentOnAnyOpenTicket()</p>
                <p class="text-gray-500 mt-1"><strong>ROLE_TECH</strong> peut commenter n'importe quel ticket ouvert.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testAssignedUserCanComment()</p>
                <p class="text-gray-500 mt-1"><strong>ROLE_USER</strong> assigné au ticket peut commenter.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testUserCannotCommentOnTicketNotAssignedToThem()</p>
                <p class="text-gray-500 mt-1"><strong>ROLE_USER</strong> non assigné → redirect avec erreur.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testCannotCommentOnClosedTicket()</p>
                <p class="text-gray-500 mt-1">Commenter un ticket fermé → redirect avec erreur.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">Assignation</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testUserCanSelfAssignUnassignedTicket()</p>
                <p class="text-gray-500 mt-1"><strong>ROLE_USER</strong> peut s'auto-assigner un ticket libre.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testUserCannotAssignAlreadyAssignedTicket()</p>
                <p class="text-gray-500 mt-1"><strong>ROLE_USER</strong> bloqué si le ticket est déjà assigné.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testTechCanAssignTicketToAnyUser()</p>
                <p class="text-gray-500 mt-1"><strong>ROLE_TECH</strong> peut assigner à n'importe quel utilisateur.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">Changement de statut</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testUserCannotReopenTicket()</p>
                <p class="text-gray-500 mt-1"><strong>ROLE_USER</strong> → JSON <code class="bg-white px-1 rounded border border-gray-200">403</code> en tentant de réouvrir.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">testTechCanReopenClosedTicket()</p>
                <p class="text-gray-500 mt-1"><strong>ROLE_TECH</strong> réouvre un ticket fermé → JSON <code class="bg-white px-1 rounded border border-gray-200">200</code> avec <code class="bg-white px-1 rounded border border-gray-200">status: "open"</code>.</p>
            </div>

        </div>
    </div>

    {# ---------------------------------------------------------------- #}
    {# Couverture #}
    {# ---------------------------------------------------------------- #}

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">Couverture de code</h2>
        <p class="text-sm text-gray-600 mb-4">
            Générée avec <strong>Xdebug 3</strong> en mode
            <code class="bg-gray-100 px-1 rounded text-xs">coverage</code>.
            Rapport HTML disponible dans <code class="bg-gray-100 px-1 rounded text-xs">var/coverage/index.html</code>.
        </p>
        <div class="space-y-3 text-sm">
            {% set items = [
                { label: 'Ticket (entity)',   pct: 100, color: 'bg-green-500' },
                { label: 'TicketType (form)', pct: 100, color: 'bg-green-500' },
                { label: 'TicketRepository',  pct: 100, color: 'bg-green-500' },
                { label: 'TicketService',     pct: 97,  color: 'bg-green-400' },
                { label: 'Comment (entity)',  pct: 92,  color: 'bg-green-400' },
                { label: 'TicketController', pct: 73,  color: 'bg-yellow-400' },
                { label: 'User (entity)',     pct: 38,  color: 'bg-red-400' },
                { label: 'UserRepository',   pct: 8,   color: 'bg-red-400' },
            ] %}
            {% for item in items %}
            <div>
                <div class="flex justify-between text-xs text-gray-600 mb-1">
                    <span>{{ item.label }}</span>
                    <span class="font-medium">{{ item.pct }}%</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-1.5">
                    <div class="{{ item.color }} h-1.5 rounded-full" style="width: {{ item.pct }}%"></div>
                </div>
            </div>
            {% endfor %}
        </div>
        <p class="text-xs text-gray-400 mt-4">
            Global : <strong class="text-gray-600">65% des lignes</strong> couvertes sur l'ensemble du projet.
        </p>
    </div>

    {# ---------------------------------------------------------------- #}
    {# Commandes #}
    {# ---------------------------------------------------------------- #}

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">Commandes</h2>
        <div class="space-y-3 font-mono">
            <div class="p-3 bg-gray-900 text-green-400 rounded-lg text-xs">
                <p class="text-gray-500 mb-1"># Lancer tous les tests</p>
                <p>php bin/phpunit</p>
            </div>
            <div class="p-3 bg-gray-900 text-green-400 rounded-lg text-xs">
                <p class="text-gray-500 mb-1"># Tests unitaires uniquement</p>
                <p>php bin/phpunit tests/Service</p>
            </div>
            <div class="p-3 bg-gray-900 text-green-400 rounded-lg text-xs">
                <p class="text-gray-500 mb-1"># Tests fonctionnels uniquement</p>
                <p>php bin/phpunit tests/Controller</p>
            </div>
            <div class="p-3 bg-gray-900 text-green-400 rounded-lg text-xs">
                <p class="text-gray-500 mb-1"># Rapport de couverture HTML</p>
                <p>php bin/phpunit --coverage-html var/coverage</p>
            </div>
            <div class="p-3 bg-gray-900 text-green-400 rounded-lg text-xs">
                <p class="text-gray-500 mb-1"># Charger les fixtures (env test)</p>
                <p>php bin/console doctrine:fixtures:load --env=test</p>
            </div>
        </div>
    </div>

</div>

{% endblock %}
