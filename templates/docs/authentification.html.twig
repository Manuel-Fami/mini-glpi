{% extends 'base.html.twig' %}

{% block title %}Authentification — Documentation — Mini GLPI{% endblock %}

{% block body %}

<div class="mb-6">
    <a href="{{ path('app_docs') }}" class="text-sm text-gray-500 hover:text-gray-700">← Documentation</a>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">Authentification</h1>
</div>

<div class="space-y-6 max-w-3xl">

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-3">Mécanisme de connexion</h2>
        <p class="text-sm text-gray-600 mb-3">
            L'authentification repose sur le composant <strong>Symfony Security</strong> avec un formulaire de login classique.
            Le firewall <code class="bg-gray-100 px-1 rounded text-xs">main</code> intercepte les soumissions sur <code class="bg-gray-100 px-1 rounded text-xs">POST /login</code>
            et délègue la vérification au provider configuré.
        </p>
        <p class="text-sm text-gray-600">
            Un token CSRF est inclus dans le formulaire pour se prémunir des attaques Cross-Site Request Forgery.
            Après connexion, l'utilisateur est redirigé vers la liste des tickets (<code class="bg-gray-100 px-1 rounded text-xs">ticket_list</code>).
        </p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">Rôles</h2>
        <div class="space-y-3 text-sm">
            <div class="flex gap-4 p-3 bg-gray-50 rounded-lg items-start">
                <span class="font-mono text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded font-semibold shrink-0">ROLE_USER</span>
                <span class="text-gray-600">Accès en lecture à tous les tickets. Peut créer un nouveau ticket. Ne peut pas assigner.</span>
            </div>
            <div class="flex gap-4 p-3 bg-gray-50 rounded-lg items-start">
                <span class="font-mono text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded font-semibold shrink-0">ROLE_TECH</span>
                <span class="text-gray-600">Tous les droits de ROLE_USER, plus la possibilité d'assigner un ticket à un technicien.</span>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">Contrôle d'accès</h2>
        <p class="text-sm text-gray-600 mb-3">Défini dans <code class="bg-gray-100 px-1 rounded text-xs">config/packages/security.yaml</code> :</p>
        <div class="space-y-2 text-sm">
            <div class="flex items-center gap-3 p-2.5 bg-gray-50 rounded-lg font-mono text-xs">
                <span class="text-gray-500">^/login</span>
                <span class="text-gray-400">→</span>
                <span class="text-green-700 font-semibold">PUBLIC_ACCESS</span>
            </div>
            <div class="flex items-center gap-3 p-2.5 bg-gray-50 rounded-lg font-mono text-xs">
                <span class="text-gray-500">^/</span>
                <span class="text-gray-400">→</span>
                <span class="text-blue-700 font-semibold">ROLE_USER</span>
            </div>
        </div>
        <p class="text-xs text-gray-400 mt-3">Seule la première règle correspondante est appliquée.</p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">Comptes de test</h2>
        <div class="space-y-3 text-sm">
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                <div>
                    <p class="font-medium text-gray-800">user@mini-glpi.fr</p>
                    <p class="text-gray-500 text-xs mt-0.5">Mot de passe : <code class="bg-white px-1 rounded border border-gray-200">password</code></p>
                </div>
                <span class="font-mono text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded font-semibold">ROLE_USER</span>
            </div>
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                <div>
                    <p class="font-medium text-gray-800">tech@mini-glpi.fr</p>
                    <p class="text-gray-500 text-xs mt-0.5">Mot de passe : <code class="bg-white px-1 rounded border border-gray-200">password</code></p>
                </div>
                <span class="font-mono text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded font-semibold">ROLE_TECH</span>
            </div>
        </div>
        <p class="text-xs text-gray-400 mt-3">Chargés via les DataFixtures : <code class="bg-gray-100 px-1 rounded">php bin/console doctrine:fixtures:load</code></p>
    </div>

</div>

{% endblock %}
