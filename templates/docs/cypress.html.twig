{% extends 'base.html.twig' %}

{% block title %}Tests Cypress — Documentation — Mini GLPI{% endblock %}

{% block body %}

<div class="mb-6">
    <a href="{{ path('app_docs') }}" class="text-sm text-gray-500 hover:text-gray-700">← Documentation</a>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">Tests Cypress</h1>
    <p class="text-sm text-gray-500 mt-1">Tests end-to-end dans un vrai navigateur</p>
</div>

<div class="space-y-6 max-w-3xl">

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-3">Pourquoi Cypress en complément de PHPUnit ?</h2>
        <p class="text-sm text-gray-600">
            PHPUnit simule les requêtes HTTP côté serveur — il n'y a pas de vrai navigateur. Tout ce qui est
            <strong>JavaScript ne peut pas être testé</strong> : mises à jour AJAX, modales, changements de visibilité.
            Cypress pilote un vrai navigateur et couvre ce que PHPUnit ne peut pas atteindre.
        </p>
        <div class="mt-4 grid grid-cols-2 gap-3 text-xs">
            <div class="p-3 bg-gray-50 rounded-lg">
                <p class="font-semibold text-gray-700 mb-2">PHPUnit couvre</p>
                <ul class="space-y-1 text-gray-500">
                    <li>✓ Logique métier PHP</li>
                    <li>✓ Règles d'autorisation HTTP</li>
                    <li>✓ Redirections et flash messages</li>
                    <li>✗ JavaScript / Stimulus</li>
                </ul>
            </div>
            <div class="p-3 bg-blue-50 rounded-lg">
                <p class="font-semibold text-blue-700 mb-2">Cypress couvre en plus</p>
                <ul class="space-y-1 text-blue-600">
                    <li>✓ Mises à jour AJAX sans rechargement</li>
                    <li>✓ Modales de confirmation</li>
                    <li>✓ Visibilité dynamique des boutons</li>
                    <li>✓ Flux complets dans le navigateur</li>
                </ul>
            </div>
        </div>
    </div>

    {# ---------------------------------------------------------------- #}
    {# Structure #}
    {# ---------------------------------------------------------------- #}

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">Structure des fichiers</h2>
        <pre class="bg-gray-900 text-green-400 rounded-lg p-4 text-xs leading-relaxed overflow-x-auto">cypress/
├── e2e/
│   ├── authentication.cy.js   ← tests de connexion
│   └── ticket-status.cy.js    ← contrôleur Stimulus
└── support/
    ├── commands.js             ← cy.login() réutilisable
    └── e2e.js                  ← point d'entrée support
cypress.config.js               ← baseUrl, specPattern…</pre>
    </div>

    {# ---------------------------------------------------------------- #}
    {# authentication.cy.js #}
    {# ---------------------------------------------------------------- #}

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">
            <code class="text-blue-600 text-sm">authentication.cy.js</code>
            <span class="ml-2 text-xs font-normal text-gray-400">4 tests</span>
        </h2>
        <div class="space-y-2">
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">affiche le formulaire de connexion</p>
                <p class="text-gray-500 mt-1">Vérifie que les champs et le bouton "Se connecter" sont présents.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">redirige vers /login si non authentifié</p>
                <p class="text-gray-500 mt-1">Accéder à <code class="bg-white px-1 rounded border border-gray-200">/tickets</code> sans session redirige vers <code class="bg-white px-1 rounded border border-gray-200">/login</code>.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">connecte un utilisateur avec des identifiants valides</p>
                <p class="text-gray-500 mt-1">Saisie du formulaire → redirection vers <code class="bg-white px-1 rounded border border-gray-200">/tickets</code>.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">affiche une erreur avec un mot de passe incorrect</p>
                <p class="text-gray-500 mt-1">Le bloc d'erreur rouge Symfony apparaît, l'URL reste <code class="bg-white px-1 rounded border border-gray-200">/login</code>.</p>
            </div>
        </div>
    </div>

    {# ---------------------------------------------------------------- #}
    {# ticket-status.cy.js #}
    {# ---------------------------------------------------------------- #}

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">
            <code class="text-blue-600 text-sm">ticket-status.cy.js</code>
            <span class="ml-2 text-xs font-normal text-gray-400">7 tests — contrôleur Stimulus</span>
        </h2>
        <p class="text-sm text-gray-600 mb-4">
            Un ticket est créé via l'interface dans le bloc <code class="bg-gray-100 px-1 rounded text-xs">before()</code>
            et réutilisé par tous les tests. La commande <code class="bg-gray-100 px-1 rounded text-xs">cy.login()</code>
            utilise <code class="bg-gray-100 px-1 rounded text-xs">cy.session()</code> pour ne s'authentifier qu'une
            seule fois par spec.
        </p>

        <div class="space-y-2">

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-1">État initial</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">le badge affiche "Ouvert" pour un ticket nouvellement créé</p>
                <p class="text-gray-500 mt-1">Vérifie l'état initial du badge et la visibilité des boutons.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">Démarrer (OPEN → IN_PROGRESS)</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">cliquer sur "Démarrer" met à jour le badge sans rechargement</p>
                <p class="text-gray-500 mt-1">Le badge passe à "En cours" via AJAX — aucun rechargement de page. Le bouton "Démarrer" se masque.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">Fermer — modale de confirmation</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">cliquer sur "Fermer" affiche la modale de confirmation</p>
                <p class="text-gray-500 mt-1">La modale devient visible avec le message attendu.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">annuler dans la modale ne modifie pas le statut</p>
                <p class="text-gray-500 mt-1">La modale se ferme et le badge ne passe pas à "Fermé".</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">confirmer la fermeture met à jour le badge et affiche "Réouvrir"</p>
                <p class="text-gray-500 mt-1">Badge → "Fermé", bouton "Réouvrir" visible, bouton "Fermer" masqué.</p>
            </div>

            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider pt-2">Réouvrir (ROLE_TECH)</p>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">cliquer sur "Réouvrir" affiche la modale de confirmation</p>
                <p class="text-gray-500 mt-1">La modale apparaît avec le message de réouverture.</p>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg text-sm">
                <p class="font-mono text-xs text-gray-800">confirmer la réouverture remet le badge à "Ouvert"</p>
                <p class="text-gray-500 mt-1">Badge → "Ouvert", bouton "Démarrer" visible, bouton "Réouvrir" masqué.</p>
            </div>

        </div>
    </div>

    {# ---------------------------------------------------------------- #}
    {# Commandes #}
    {# ---------------------------------------------------------------- #}

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-4">Commandes</h2>
        <div class="space-y-3 font-mono">
            <div class="p-3 bg-gray-900 text-green-400 rounded-lg text-xs">
                <p class="text-gray-500 mb-1"># Démarrer le serveur Symfony (obligatoire)</p>
                <p>symfony server:start</p>
            </div>
            <div class="p-3 bg-gray-900 text-green-400 rounded-lg text-xs">
                <p class="text-gray-500 mb-1"># Interface graphique (recommandé)</p>
                <p>npm run cypress:open</p>
            </div>
            <div class="p-3 bg-gray-900 text-green-400 rounded-lg text-xs">
                <p class="text-gray-500 mb-1"># Mode terminal (CI)</p>
                <p>npm run cypress:run</p>
            </div>
        </div>
    </div>

</div>

{% endblock %}
