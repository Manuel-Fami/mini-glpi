{% extends 'base.html.twig' %}

{% block title %}Ticket #{{ ticket.id }} — Mini GLPI{% endblock %}

{% block body %}

{#
    Le data-controller="status" englobe tout le bloc.
    Les targets (badge, start, close, modify, error) peuvent être
    n'importe où à l'intérieur de cet élément.
#}
<div data-controller="status"
     data-status-url-value="{{ path('ticket_status', {id: ticket.id}) }}"
     data-status-token-value="{{ csrf_token('ticket_status_' ~ ticket.id) }}">

<div class="mb-6 flex items-center justify-between flex-wrap gap-3">
    <div>
        <a href="{{ path('ticket_list') }}" class="text-sm text-gray-500 hover:text-gray-700">← Retour à la liste</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">Ticket #{{ ticket.id }}</h1>
    </div>

    <div class="flex gap-2 items-center flex-wrap">

        {# Zone d'erreur AJAX #}
        <span data-status-target="error"
              class="hidden text-xs font-medium text-red-700 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></span>

        {# Lien Modifier — masqué dès que le statut passe à CLOSED #}
        <a href="{{ path('ticket_edit', {id: ticket.id}) }}"
           data-status-target="modify"
           class="text-sm px-4 py-2 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 transition
                  {{ ticket.status.value == 'closed' ? 'hidden' : '' }}">
            Modifier
        </a>

        {# Bouton Démarrer — visible uniquement si OPEN #}
        <button type="button"
                data-status-target="start"
                data-action="click->status#start"
                class="text-sm px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition cursor-pointer
                       {{ ticket.status.value != 'open' ? 'hidden' : '' }}">
            Démarrer la prise en charge
        </button>

        {# Bouton Fermer — visible si pas déjà CLOSED #}
        <button type="button"
                data-status-target="close"
                data-action="click->status#close"
                class="text-sm px-4 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white transition cursor-pointer
                       {{ ticket.status.value == 'closed' ? 'hidden' : '' }}">
            Fermer
        </button>

        {# Bouton Réouvrir — ROLE_TECH uniquement, visible si CLOSED #}
        {% if is_granted('ROLE_TECH') %}
        <button type="button"
                data-status-target="reopen"
                data-action="click->status#reopen"
                class="text-sm px-4 py-2 rounded-lg bg-gray-600 hover:bg-gray-700 text-white transition cursor-pointer
                       {{ ticket.status.value != 'closed' ? 'hidden' : '' }}">
            Réouvrir
        </button>
        {% endif %}

    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 p-4">

    {# Détail principal #}
    <div class="lg:col-span-2 space-y-6">

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
            <h2 class="text-lg font-semibold text-gray-900 mb-1">{{ ticket.title }}</h2>
            <p class="text-sm text-gray-400 mb-4">
                Créé le {{ ticket.createdAt|date('d/m/Y à H:i') }}
                par <span class="font-medium text-gray-600">{{ ticket.createdBy.userIdentifier }}</span>
            </p>
            <div class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">
                {{ ticket.description }}
            </div>
        </div>

        {# Section commentaires #}
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
            <h3 class="text-sm font-semibold text-gray-700 mb-4">
                Commentaires
                {% if ticket.comments|length > 0 %}
                    <span class="ml-1 text-xs font-medium text-gray-400">({{ ticket.comments|length }})</span>
                {% endif %}
            </h3>

            {% if ticket.comments is empty %}
                <p class="text-sm text-gray-400 italic">Aucun commentaire pour le moment.</p>
            {% else %}
                <div class="space-y-4 mb-6">
                    {% for comment in ticket.comments %}
                    <div class="flex gap-3">
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center text-xs font-bold uppercase">
                            {{ comment.author.userIdentifier|slice(0, 1) }}
                        </div>
                        <div class="flex-1">
                            <div class="flex items-baseline gap-2 mb-1">
                                <span class="text-sm font-medium text-gray-800">{{ comment.author.userIdentifier }}</span>
                                <span class="text-xs text-gray-400">{{ comment.createdAt|date('d/m/Y à H:i') }}</span>
                            </div>
                            <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{{ comment.content }}</p>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% endif %}

            {% if canComment %}
                <form action="{{ path('ticket_comment', {id: ticket.id}) }}" method="post"
                      class="{{ ticket.comments is not empty ? 'border-t border-gray-100 pt-4' : '' }}">
                    <textarea name="content"
                              rows="3"
                              placeholder="Laisser un commentaire…"
                              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none mb-3"></textarea>
                    <button type="submit"
                            class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition cursor-pointer">
                        Publier
                    </button>
                </form>
            {% endif %}
        </div>

    </div>

    {# Panneau latéral #}
    <div class="space-y-4 mt-6 lg:mt-0">

        {# Statut & priorité #}
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Informations</h3>

            <dl class="space-y-3 text-sm">
                <div class="flex justify-between items-center">
                    <dt class="text-gray-500">Statut</dt>
                    <dd>
                        {# Badge mis à jour dynamiquement par le contrôleur Stimulus #}
                        <span data-status-target="badge"
                              class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-medium
                                     {% if ticket.status.value == 'open' %}bg-yellow-100 text-yellow-800
                                     {% elseif ticket.status.value == 'in_progress' %}bg-blue-100 text-blue-800
                                     {% else %}bg-gray-100 text-gray-600{% endif %}">
                            {% if ticket.status.value == 'open' %}Ouvert
                            {% elseif ticket.status.value == 'in_progress' %}En cours
                            {% else %}Fermé{% endif %}
                        </span>
                    </dd>
                </div>
                <div class="flex justify-between items-center">
                    <dt class="text-gray-500">Priorité</dt>
                    <dd class="font-medium text-gray-700">
                        {% if ticket.priority == 'CRITICAL' %}
                            <span class="text-red-600 font-semibold">Critique</span>
                        {% elseif ticket.priority == 'HIGH' %}
                            <span class="text-orange-500 font-semibold">Haute</span>
                        {% elseif ticket.priority == 'MEDIUM' %}
                            <span class="text-yellow-600">Moyenne</span>
                        {% else %}
                            <span class="text-gray-500">Basse</span>
                        {% endif %}
                    </dd>
                </div>
                <div class="flex justify-between items-center">
                    <dt class="text-gray-500">Assigné à</dt>
                    <dd class="font-medium text-gray-700">
                        {{ ticket.assignedTo ? ticket.assignedTo.userIdentifier : '—' }}
                    </dd>
                </div>
            </dl>
        </div>

        {# Assignation #}
        {% if ticket.status.value != 'closed' %}

            {% if is_granted('ROLE_TECH') %}
            {# Tech : peut assigner à n'importe qui, peut réassigner #}
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">
                    {{ ticket.assignedTo ? 'Réassigner le ticket' : 'Assigner le ticket' }}
                </h3>
                <form action="{{ path('ticket_assign', {id: ticket.id}) }}" method="post">
                    <select name="user_id"
                            class="w-full px-3 py-2 rounded-lg border border-gray-300 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 mb-3 cursor-pointer">
                        {% for user in allUsers %}
                            <option value="{{ user.id }}"
                                    {{ ticket.assignedTo and ticket.assignedTo.id == user.id ? 'selected' : '' }}>
                                {{ user.userIdentifier }}
                            </option>
                        {% endfor %}
                    </select>
                    <button type="submit"
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 rounded-lg transition cursor-pointer">
                        {{ ticket.assignedTo ? 'Réassigner' : 'Assigner' }}
                    </button>
                </form>
            </div>

            {% elseif ticket.assignedTo is null %}
            {# User : peut uniquement s'auto-assigner si le ticket n'est pas déjà assigné #}
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Prendre en charge</h3>
                <form action="{{ path('ticket_assign', {id: ticket.id}) }}" method="post">
                    <button type="submit"
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 rounded-lg transition cursor-pointer">
                        M'assigner ce ticket
                    </button>
                </form>
            </div>
            {% endif %}

        {% endif %}

    </div>
</div>

{# Modale de confirmation #}
<div data-status-target="modal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white rounded-2xl shadow-xl p-6 max-w-sm w-full mx-4">
        <p data-status-target="modalMessage"
           class="text-sm text-gray-700 mb-5 text-center leading-relaxed"></p>
        <div class="flex gap-3">
            <button type="button"
                    data-action="click->status#cancelModal"
                    class="flex-1 px-4 py-2 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm transition cursor-pointer">
                Annuler
            </button>
            <button type="button"
                    data-action="click->status#confirmModal"
                    class="flex-1 px-4 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm font-medium transition cursor-pointer">
                Confirmer
            </button>
        </div>
    </div>
</div>

</div>{# /data-controller="status" #}

{% endblock %}
